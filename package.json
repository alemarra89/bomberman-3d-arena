    "test:e2e:report": "playwright show-report",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@babylonjs/core": "^8.36.0",
    "@babylonjs/gui": "^8.36.0",
    "@vitejs/plugin-react": "^5.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "reactylon": "^3.5.7"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-reactylon": "^1.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
