{
  "name": "bomberman-3d-arena",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/dev.mjs",
    "client": "vite --host 0.0.0.0",
    "server": "node server/api.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test:e2e": "playwright test",
